# ntfy 認証情報サンプル
# 実ファイルは config/ntfy_auth.env として配置（.gitignore 済み・コミット禁止）
# 使い方:
#   cp config/ntfy_auth.env.sample config/ntfy_auth.env
#   chmod 600 config/ntfy_auth.env

# 必須: トピック名（推測されにくい長めの文字列を推奨）
NTFY_TOPIC=ojousama-yourrandomstring

# 任意: ntfy サーバー（自前ホストの場合は変更）
NTFY_SERVER=https://ntfy.sh

# 認証は Bearer か Basic のどちらか一方を有効化する
# --- Bearer ---
# NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Basic ---
# NTFY_USER=username
# NTFY_PASS=password
